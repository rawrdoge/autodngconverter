# RawImport Pipeline — local .env (NOT committed; gitignored)
# Copy to ".env" and fill in your LIVE MariaDB credentials.
# The binary reads this file via loadDotEnv() when present.
# Real environment variables always take precedence over this file.

# --- MariaDB connection (PRD §4.2.5, §6) ---
DB_DRIVER=mariadb
DB_HOST=your-mariadb-host
DB_PORT=3306
DB_USER=rawimport
DB_PASSWORD=change-me
DB_NAME=rawimport

# --- Converter engine (PRD §1.1) ---
CONVERTER_ENGINE=dnglab
# Path to the forked vibelabdng (dnglab fork) binary (default "dnglab" on PATH)
DNGLAB_BIN=./vibelabdng/target/release/dnglab.exe

# --- EXIF / thumbnail extraction (PRD Q5, Q8) ---
# Path to exiftool binary (default "exiftool" on PATH)
EXIFTOOL_BIN=exiftool

# --- Pipeline paths (local test layout) ---
WATCH_DIR=./testdata/watch
OUTPUT_DIR=./testdata/output
ARCHIVE_DIR=./testdata/archive

 # --- Folder / naming (PRD §4.2.4) ---
 FOLDER_SCHEMA=%Y/%m
 FILE_PATTERN=IMG_{seq}

 # --- Default conversion settings (applied to every new import; reconversions can override) ---
 # These are forwarded to the dnglab `convert` subcommand. See converter.go / vibelabdng app.rs.
 DEF_COMPRESSION=lossless        # lossless | uncompressed
 DEF_DNG_VERSION=1.4             # 1.4 | 1.6
 DEF_PREVIEW_MEDIUM=1024x1024    # medium preview size WxH
 DEF_PREVIEW_FULL=4000x3000      # full preview size WxH
 DEF_JPEG_QUALITY=92             # JPEG preview quality 0-100
 DEF_LINEAR=false                # write a linear (demosaiced) DNG

 # --- Sidecar thumbnail JPEG ---
 # Write a standalone IMG_n.thumb.jpg next to each DNG in /output. OFF by default
 # so the output library contains only DNGs. Set true to enable.
 GEN_THUMB_JPEG=false

 # --- Misc ---
 POLL_INTERVAL=5
 PORT=8080
 LOG_LEVEL=info

# --- Preview re-embed notify (PRD Q8) ---
# Optional bearer token. If set, the notify endpoint requires
# `Authorization: Bearer <API_TOKEN>`. If empty, the endpoint is open (LAN-only).
API_TOKEN=
# Base URL the Darktable Lua script posts preview-edit notifications to.
# Leave empty to disable DB sync (preview edits won't update output_hash).
RAWIMPORT_API_URL=http://localhost:8080
